{
  "name": "my-app-kvitali",
  "version": "0.2.3",
  "homepage": "https://vitalikevin.github.io/ci-cd",
  "private": false,
  "dependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^13.5.0",
    "axios": "^1.18.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-scripts": "5.0.1",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test --coverage --verbose --collectCoverageFrom=src/*.js --collectCoverageFrom=!src/reportWebVitals.js --collectCoverageFrom=!src/index.js --watchAll=false",
    "eject": "react-scripts eject",
    "jsdoc": "jsdoc -R ./README.md -c ./jsdoc.config.json -r -d ./public/docs",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d build",
    "build-npm": "cross-env NODE_ENV=production rm -rf dist && mkdir -p dist && npx babel src --out-dir dist --copy-files",
    "build-npm-ci": "NODE_ENV=production rm -rf dist && mkdir -p dist && npx babel src --out-dir dist --copy-files",
    "cypress": "cypress open"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "overrides": {
    "yaml": "^2.8.4"
  },
  "devDependencies": {
    "@babel/cli": "^7.29.7",
    "@babel/core": "^7.29.7",
    "@babel/plugin-transform-react-jsx": "^7.29.7",
    "@babel/preset-env": "^7.29.3",
    "babel-jest": "^30.3.0",
    "cross-env": "^10.1.0",
    "cypress": "^15.17.0",
    "gh-pages": "^6.3.0",
    "jsdoc": "^4.0.5"
  }
}
